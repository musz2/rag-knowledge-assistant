APP_NAME=RAG Knowledge Assistant
DATA_DIR=data
UPLOADS_DIR=data/uploads
INDEX_PATH=data/index/vector_store.json

# local is deterministic and works without external services.
EMBEDDING_PROVIDER=local
LLM_PROVIDER=local

# OpenAI mode:
# EMBEDDING_PROVIDER=openai
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# Llama/Ollama mode:
# LLM_PROVIDER=llama
# LLAMA_BASE_URL=http://ollama:11434
# LLAMA_MODEL=llama3.1

CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=4
